{
  "name": "daq-analytics",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"cross-env BROWSER=none npm start --prefix frontend\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "electron-builder",
    "package": "electron-packager . DAQ-Analytics --platform=win32 --arch=x64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.8.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.2",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron-packager": "^17.1.2",
    "electron-reload": "^2.0.0-alpha.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.daq.analytics",
    "productName": "DAQ Analytics",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "repo": "daq-analytics",
        "owner": "your-github-username",
        "releaseType": "draft"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
